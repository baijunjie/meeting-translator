{
  "name": "meeting-translator",
  "version": "0.1.0",
  "description": "Local real-time meeting transcription for macOS",
  "main": "./out/main/index.js",
  "scripts": {
    "postinstall": "node node_modules/electron/install.js",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "type-check": "vue-tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf out dist-test",
    "download-models": "bash scripts/download-models.sh",
    "test-pipeline": "tsc -p tsconfig.test.json && node dist-test/test/pipeline.js",
    "test-translate": "tsc -p tsconfig.test.json && node dist-test/test/translate.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@lucide/vue": "^1.21.0",
    "electron": "^42.4.0",
    "naive-ui": "^2.44.1",
    "sherpa-onnx-node": "^1.13.2",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "electron-vite": "^5.0.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.6",
    "vue-tsc": "^3.3.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "onnxruntime-node"
    ]
  }
}
