{
  "name": "realtime-translator-monorepo",
  "version": "0.1.0-beta.1",
  "description": "Local, real-time speech transcription & translation for macOS, iOS, and the browser (monorepo)",
  "private": true,
  "scripts": {
    "postinstall": "node node_modules/electron/install.js",
    "dev": "pnpm --filter @rt/macos dev",
    "build": "pnpm --filter @rt/macos build",
    "type-check": "pnpm --filter @rt/macos type-check",
    "dist": "pnpm --filter @rt/macos dist",
    "dist:dir": "pnpm --filter @rt/macos dist:dir",
    "set-version": "node scripts/set-version.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "onnxruntime-node",
      "sharp"
    ],
    "overrides": {
      "string-width": "^4.2.3"
    }
  }
}
